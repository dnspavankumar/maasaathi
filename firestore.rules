rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Check user role from the 'users' collection
    function getRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // ASHA workers can manage patients in their village
    match /patients/{patientId} {
      allow read, write: if isSignedIn() && (
        getRole(request.auth.uid) == 'asha' || 
        getRole(request.auth.uid) == 'doctor' || 
        request.auth.uid == resource.data.id // Mother reading her own metadata
      );
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Surveys rules
    match /surveys/{surveyId} {
      allow read: if isSignedIn() && (
        getRole(request.auth.uid) == 'asha' || 
        getRole(request.auth.uid) == 'doctor' || 
        request.auth.uid == resource.data.patientId
      );
      allow create, update: if isSignedIn() && getRole(request.auth.uid) == 'asha';
    }

    // Vitals rules (Real-time ring data)
    match /vitals/{vitalId} {
      allow read: if isSignedIn() && (
        getRole(request.auth.uid) == 'asha' || 
        getRole(request.auth.uid) == 'doctor' || 
        request.auth.uid == resource.data.patientId
      );
      allow create: if isSignedIn(); // Ring can push
    }

    // Alerts rules
    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }
  }
}
